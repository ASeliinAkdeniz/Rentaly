@model List<Rentaly.EntityLayer.Entities.OurFuture>
@{
    ViewData["Title"] = "Geleceğimiz";
    ViewData["ActiveMenu"] = "OurFuture";
    ViewData["BreadcrumbParent"] = "İçerik Yönetimi";
    Layout = "_AdminLayout";
}

<style>
    .future-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .future-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }

        .future-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            border-color: var(--accent2);
        }

    .future-img {
        height: 140px;
        background: var(--bg2);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .future-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .future-img i {
            font-size: 40px;
            color: var(--navy);
            opacity: .2;
        }

    .future-body {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .future-title {
        font-size: 14.5px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .future-desc {
        font-size: 12.5px;
        color: var(--text-muted);
        line-height: 1.5;
        flex: 1;
    }

    .future-actions {
        padding: 12px 16px;
        border-top: 1px solid var(--bg2);
        display: flex;
        gap: 8px;
    }

    .action-btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fef3c7;
        color: #92400e;
        border: none;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
        flex: 1;
        justify-content: center;
    }

        .action-btn-edit:hover {
            background: #f59e0b;
            color: #fff;
        }

    .action-btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fee2e2;
        color: #be123c;
        border: none;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
    }

        .action-btn-delete:hover {
            background: var(--danger);
            color: #fff;
        }

    .empty-state {
        padding: 64px 20px;
        text-align: center;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        background: var(--bg2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: var(--navy);
        margin: 0 auto 18px;
    }

    .img-preview-wrap {
        display: none;
        margin-top: 8px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .img-preview-wrap img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            display: block;
        }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Geleceğimiz</h1>
        <p class="page-subtitle">Ana sayfada gösterilecek "geleceğimiz" içeriklerini yönetin.</p>
    </div>
    <button type="button" class="btn-add" onclick="openCreateModal()">
        <i class="ti ti-plus"></i> Yeni İçerik
    </button>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(2,1fr);max-width:480px;margin-bottom:22px;">
    <div class="stat-card">
        <div class="stat-icon navy"><i class="ti ti-leaf"></i></div>
        <div>
            <div class="stat-label">Toplam İçerik</div>
            <div class="stat-value">@Model.Count()</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="ti ti-photo"></i></div>
        <div>
            <div class="stat-label">Görselli</div>
            <div class="stat-value">@Model.Count(f => !string.IsNullOrEmpty(f.ImageUrl))</div>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <div class="future-grid">
        @foreach (var f in Model)
        {
            <div class="future-card">
                <div class="future-img">
                    @if (!string.IsNullOrEmpty(f.ImageUrl))
                    {
                        <img src="@f.ImageUrl" alt="@f.Title" onerror="this.parentElement.innerHTML='<i class=&quot;ti ti-leaf&quot;></i>'" />
                    }
                    else
                    {
                        <i class="ti ti-leaf"></i>
                    }
                </div>
                <div class="future-body">
                    <div class="future-title">@f.Title</div>
                    <div class="future-desc">@f.Description</div>
                </div>
                <div class="future-actions">
                    <button type="button" class="action-btn-edit"
                            onclick="openEditModal(@f.OurFutureId, '@Html.Raw(f.Title?.Replace("'", "\\'"))', '@Html.Raw(f.Description?.Replace("'", "\\'"))', '@Html.Raw(f.ImageUrl)')">
                        <i class="ti ti-pencil"></i> Düzenle
                    </button>
                    <button type="button" class="action-btn-delete"
                            onclick="openDeleteModal(@f.OurFutureId, '@Html.Raw(f.Title?.Replace("'", "\\'"))')">
                        <i class="ti ti-trash"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-icon"><i class="ti ti-leaf"></i></div>
        <h6 style="font-weight:700;margin-bottom:6px;color:var(--text-primary);">Henüz İçerik Eklenmemiş</h6>
        <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:14px;">Ana sayfada gösterilecek ilk içeriği ekleyin.</p>
        <button type="button" onclick="openCreateModal()" class="btn-add">
            <i class="ti ti-plus"></i> Yeni İçerik Ekle
        </button>
    </div>
}

<!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content" style="border:none;border-radius:14px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border);padding:20px 24px;background:var(--bg2);border-radius:14px 14px 0 0;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:38px;height:38px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;">
                        <i class="ti ti-plus" style="font-size:18px;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" style="font-size:15px;font-weight:700;color:var(--text-primary);margin:0;">Yeni İçerik Ekle</h5>
                        <p style="font-size:11px;color:var(--text-muted);margin:0;">Geleceğimiz içeriği bilgilerini girin</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createForm" asp-area="Admin" asp-controller="OurFuture" asp-action="CreateOurFuture" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding:24px;">
                    <div class="mb-3">
                        <label class="form-label">Başlık <span style="color:var(--danger);">*</span></label>
                        <input type="text" name="Title" id="createTitle" class="form-control"
                               placeholder="örn. Sürdürülebilir Filomuz" maxlength="100" />
                        <span id="createTitleError" style="font-size:12px;color:var(--danger);display:none;">
                            <i class="ti ti-alert-circle"></i> Başlık zorunludur.
                        </span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama <span style="color:var(--danger);">*</span></label>
                        <textarea name="Description" id="createDescription" class="form-control" rows="3"
                                  placeholder="İçeriği kısaca açıklayın…" maxlength="400"></textarea>
                        <span id="createDescriptionError" style="font-size:12px;color:var(--danger);display:none;">
                            <i class="ti ti-alert-circle"></i> Açıklama zorunludur.
                        </span>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Görsel URL</label>
                        <input type="text" name="ImageUrl" id="createImageUrl" class="form-control"
                               placeholder="https://example.com/image.jpg" oninput="previewImg(this.value, 'createPreview')" />
                        <div class="img-preview-wrap" id="createPreviewWrap">
                            <img id="createPreview" src="" alt="Önizleme" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border);padding:16px 24px;background:var(--bg2);border-radius:0 0 14px 14px;display:flex;justify-content:flex-end;gap:8px;">
                    <button type="button" class="btn-edit" data-bs-dismiss="modal">
                        <i class="ti ti-x"></i> Vazgeç
                    </button>
                    <button type="button" class="btn-add" onclick="submitCreate()">
                        <i class="ti ti-check"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content" style="border:none;border-radius:14px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border);padding:20px 24px;background:var(--bg2);border-radius:14px 14px 0 0;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:38px;height:38px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;">
                        <i class="ti ti-pencil" style="font-size:18px;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" style="font-size:15px;font-weight:700;color:var(--text-primary);margin:0;">İçerik Düzenle</h5>
                        <p style="font-size:11px;color:var(--text-muted);margin:0;">Bilgileri güncelleyin</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-area="Admin" asp-controller="OurFuture" asp-action="UpdateOurFuture" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editOurFutureId" name="OurFutureId" />
                <div class="modal-body" style="padding:24px;">
                    <div class="mb-3">
                        <label class="form-label">Başlık <span style="color:var(--danger);">*</span></label>
                        <input type="text" name="Title" id="editTitle" class="form-control" maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama <span style="color:var(--danger);">*</span></label>
                        <textarea name="Description" id="editDescription" class="form-control" rows="3" maxlength="400"></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Görsel URL</label>
                        <input type="text" name="ImageUrl" id="editImageUrl" class="form-control"
                               oninput="previewImg(this.value, 'editPreview')" />
                        <div class="img-preview-wrap" id="editPreviewWrap">
                            <img id="editPreview" src="" alt="Önizleme" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border);padding:16px 24px;background:var(--bg2);border-radius:0 0 14px 14px;display:flex;justify-content:flex-end;gap:8px;">
                    <button type="button" class="btn-edit" data-bs-dismiss="modal">
                        <i class="ti ti-x"></i> Vazgeç
                    </button>
                    <button type="submit" class="btn-add">
                        <i class="ti ti-check"></i> Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border:none;border-radius:14px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border);padding:18px 22px;background:var(--bg2);border-radius:14px 14px 0 0;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:#fee2e2;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--danger);">
                        <i class="ti ti-trash" style="font-size:16px;"></i>
                    </div>
                    <h5 class="modal-title" style="font-size:15px;font-weight:700;color:var(--text-primary);margin:0;">İçerik Sil</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:22px;">
                <div style="display:flex;gap:14px;align-items:flex-start;">
                    <div style="width:46px;height:46px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--danger);font-size:20px;flex-shrink:0;">
                        <i class="ti ti-alert-triangle"></i>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14.5px;color:var(--text-primary);line-height:1.5;">
                            <strong id="deleteFutureTitle">bu içeriği</strong> silmek istediğinizden emin misiniz?
                        </p>
                        <p style="margin:6px 0 0;font-size:13px;color:var(--text-muted);">Bu işlem geri alınamaz.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);padding:14px 22px;background:var(--bg2);border-radius:0 0 14px 14px;display:flex;justify-content:flex-end;gap:8px;">
                <button type="button" class="btn-edit" data-bs-dismiss="modal">
                    <i class="ti ti-x"></i> Vazgeç
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteFutureId" name="id" />
                    <button type="submit" style="display:inline-flex;align-items:center;gap:7px;background:var(--danger);color:#fff;border:none;border-radius:9px;padding:9px 22px;font-size:13.5px;font-weight:700;cursor:pointer;">
                        <i class="ti ti-trash"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Success"]', 'success'));</script>
}

<script>
    function previewImg(url, imgId) {
        const wrap = document.getElementById(imgId + 'Wrap');
        const img = document.getElementById(imgId);
        if (!url) { wrap.style.display = 'none'; return; }
        img.src = url;
        img.onload = () => wrap.style.display = 'block';
        img.onerror = () => wrap.style.display = 'none';
    }

    function openCreateModal() {
        document.getElementById('createTitle').value = '';
        document.getElementById('createDescription').value = '';
        document.getElementById('createImageUrl').value = '';
        document.getElementById('createPreviewWrap').style.display = 'none';
        document.getElementById('createTitleError').style.display = 'none';
        document.getElementById('createDescriptionError').style.display = 'none';
        new bootstrap.Modal(document.getElementById('createModal')).show();
    }

    function submitCreate() {
        const t = document.getElementById('createTitle').value.trim();
        const d = document.getElementById('createDescription').value.trim();
        document.getElementById('createTitleError').style.display = !t ? 'block' : 'none';
        document.getElementById('createDescriptionError').style.display = !d ? 'block' : 'none';
        if (!t || !d) return;
        document.getElementById('createForm').submit();
    }

    function openEditModal(id, title, description, imageUrl) {
        document.getElementById('editOurFutureId').value = id;
        document.getElementById('editTitle').value = title;
        document.getElementById('editDescription').value = description;
        document.getElementById('editImageUrl').value = imageUrl || '';
        previewImg(imageUrl, 'editPreview');
        new bootstrap.Modal(document.getElementById('editModal')).show();
    }

    function openDeleteModal(id, title) {
        document.getElementById('deleteFutureTitle').textContent = '"' + title + '"';
        document.getElementById('deleteFutureId').value = id;
        document.getElementById('deleteForm').action = '/Admin/OurFuture/DeleteOurFuture/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>

