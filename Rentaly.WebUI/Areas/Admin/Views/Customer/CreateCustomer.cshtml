@model Rentaly.DTOLayer.CustomerDtos.CreateCustomerDto
@{
    ViewData["Title"] = "Yeni Müşteri";
    ViewData["ActiveMenu"] = "Customer";
    ViewData["BreadcrumbParent"] = "Operasyon";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Müşteri Ekle</h1>
        <p class="page-subtitle">Sisteme yeni bir müşteri kaydı oluşturun.</p>
    </div>
    <a asp-area="Admin" asp-controller="Customer" asp-action="CustomerList" class="btn-edit">
        <i class="ti ti-arrow-left"></i> Listeye Dön
    </a>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <form asp-area="Admin" asp-controller="Customer" asp-action="CreateCustomer" method="post">
            @Html.AntiForgeryToken()

            <!-- Kişisel Bilgiler -->
            <div class="form-card mb-4">
                <div class="form-card-title">
                    <i class="ti ti-user me-2" style="color:var(--accent2);"></i>Kişisel Bilgiler
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Ad <span style="color:var(--danger);">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="örn. Ahmet" />
                        <span asp-validation-for="Name" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Soyad <span style="color:var(--danger);">*</span></label>
                        <input asp-for="Surname" class="form-control" placeholder="örn. Yılmaz" />
                        <span asp-validation-for="Surname" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">E-posta</label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" type="email" />
                        <span asp-validation-for="Email" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Telefon</label>
                        <input asp-for="Phone" class="form-control" placeholder="05XX XXX XX XX" />
                        <span asp-validation-for="Phone" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">TC Kimlik No</label>
                        <input asp-for="IdentityNumber" class="form-control" placeholder="XXXXXXXXXXX" maxlength="11" />
                        <span asp-validation-for="IdentityNumber" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                </div>
            </div>

            <!-- Ehliyet Bilgileri -->
            <div class="form-card mb-4">
                <div class="form-card-title">
                    <i class="ti ti-id-badge me-2" style="color:var(--accent2);"></i>Ehliyet Bilgileri
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Ehliyet No</label>
                        <input asp-for="DrivingLicenseNumber" class="form-control" placeholder="Ehliyet numarası" />
                        <span asp-validation-for="DrivingLicenseNumber" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ehliyet Tarihi</label>
                        <input asp-for="DrivingLicenseDate" class="form-control" type="date" />
                        <span asp-validation-for="DrivingLicenseDate" style="font-size:12px;color:var(--danger);"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-area="Admin" asp-controller="Customer" asp-action="CustomerList" class="btn-edit">
                    <i class="ti ti-x"></i> Vazgeç
                </a>
                <button type="submit" class="btn-add">
                    <i class="ti ti-check"></i> Müşteriyi Kaydet
                </button>
            </div>
        </form>
    </div>

    <!-- Sağ panel -->
    <div class="col-12 col-lg-4">
        <div class="form-card">
            <div class="form-card-title">
                <i class="ti ti-info-circle me-2" style="color:var(--accent2);"></i>Bilgi
            </div>
            <div style="display:flex;flex-direction:column;gap:12px;">
                <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text-muted);">
                    <i class="ti ti-circle-check" style="color:var(--accent2);margin-top:1px;font-size:15px;flex-shrink:0;"></i>
                    <span>Ad ve soyad zorunlu alanlardır.</span>
                </div>
                <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text-muted);">
                    <i class="ti ti-circle-check" style="color:var(--accent2);margin-top:1px;font-size:15px;flex-shrink:0;"></i>
                    <span>TC Kimlik No 11 haneli olmalıdır.</span>
                </div>
                <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text-muted);">
                    <i class="ti ti-circle-check" style="color:var(--accent2);margin-top:1px;font-size:15px;flex-shrink:0;"></i>
                    <span>Ehliyet bilgileri rezervasyon onayı için gereklidir.</span>
                </div>
                <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text-muted);">
                    <i class="ti ti-circle-check" style="color:var(--accent2);margin-top:1px;font-size:15px;flex-shrink:0;"></i>
                    <span>E-posta, rezervasyon onay maili için kullanılacaktır.</span>
                </div>
            </div>
        </div>
    </div>
</div>