<script>
    let currentView = 'grid';
    let currentPage = 1;
    const PAGE_SIZE = 12;

    function setView(v) {
        currentView = v;
        document.getElementById('customersGrid').style.display = v === 'grid' ? 'grid' : 'none';
        document.getElementById('customersList').style.display = v === 'list' ? 'flex' : 'none';
        document.getElementById('btnGridView').classList.toggle('active', v === 'grid');
        document.getElementById('btnListView').classList.toggle('active', v === 'list');
        currentPage = 1;
        applyFilters();
    }

    function filterCustomers() { currentPage = 1; applyFilters(); }

    function applyFilters() {
        const q    = document.getElementById('customerSearch').value.toLowerCase().trim();
        const sort = document.getElementById('sortSelect').value;

        const gridCards = [...document.querySelectorAll('#customersGrid .customer-card')];
        const listItems = [...document.querySelectorAll('#customersList .customer-list-item')];

        const filterItem = (item) => {
            if (!q) return true;
            return (item.dataset.name    || '').includes(q) ||
                   (item.dataset.surname || '').includes(q) ||
                   (item.dataset.email   || '').includes(q) ||
                   (item.dataset.phone   || '').includes(q) ||
                   (item.dataset.id      || '').includes(q);
        };

        gridCards.forEach(c => c.setAttribute('data-show', filterItem(c) ? '1' : '0'));
        listItems.forEach(c => c.setAttribute('data-show', filterItem(c) ? '1' : '0'));

        const [sortField, sortDir] = sort.split('-');
        const sortItems = (list) => {
            list.sort((a, b) => {
                let va, vb;
                if      (sortField === 'id')      { va = parseInt(a.dataset.id);      vb = parseInt(b.dataset.id); }
                else if (sortField === 'name')    { va = a.dataset.name    || '';     vb = b.dataset.name    || ''; }
                else if (sortField === 'surname') { va = a.dataset.surname || '';     vb = b.dataset.surname || ''; }
                else if (sortField === 'license') { va = parseInt(a.dataset.licenseDate) || 0; vb = parseInt(b.dataset.licenseDate) || 0; }
                if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb, 'tr') : vb.localeCompare(va, 'tr');
                return sortDir === 'asc' ? va - vb : vb - va;
            });
        };

        sortItems(gridCards);
        sortItems(listItems);
        gridCards.forEach(c => document.getElementById('customersGrid').appendChild(c));
        listItems.forEach(c => document.getElementById('customersList').appendChild(c));
        buildPaging();
    }

    function resetCustomerFilters() {
        document.getElementById('customerSearch').value = '';
        document.getElementById('sortSelect').value = 'id-asc';
        currentPage = 1;
        applyFilters();
        showToast('Filtreler sıfırlandı.', 'success');
    }

    function buildPaging() {
        const activeItems = currentView === 'grid'
            ? [...document.querySelectorAll('#customersGrid .customer-card')]
            : [...document.querySelectorAll('#customersList .customer-list-item')];

        const filtered = activeItems.filter(c => c.getAttribute('data-show') === '1');
        const total = filtered.length;
        const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > pages) currentPage = pages;

        activeItems.forEach(c => c.style.display = 'none');
        filtered.forEach((c, i) => {
            if (i >= (currentPage - 1) * PAGE_SIZE && i < currentPage * PAGE_SIZE) c.style.display = '';
        });

        const inactiveItems = currentView === 'grid'
            ? [...document.querySelectorAll('#customersList .customer-list-item')]
            : [...document.querySelectorAll('#customersGrid .customer-card')];
        inactiveItems.forEach(c => c.style.display = 'none');

        document.getElementById('emptyState').style.display = total === 0 ? 'block' : 'none';

        const from = total === 0 ? 0 : (currentPage - 1) * PAGE_SIZE + 1;
        const to   = Math.min(currentPage * PAGE_SIZE, total);
        document.getElementById('pagingInfo').textContent = total > 0 ? `${from}–${to} / toplam ${total} müşteri` : '0 müşteri';

        const btns = document.getElementById('pagingBtns');
        btns.innerHTML = '';

        const prev = makePageBtn('<i class="ti ti-chevron-left" style="font-size:11px;"></i>', () => goPage(currentPage - 1));
        if (currentPage === 1) prev.disabled = true;
        btns.appendChild(prev);

        for (let p = 1; p <= pages; p++) {
            const btn = makePageBtn(p, () => goPage(p));
            if (p === currentPage) btn.classList.add('active');
            btns.appendChild(btn);
        }

        const next = makePageBtn('<i class="ti ti-chevron-right" style="font-size:11px;"></i>', () => goPage(currentPage + 1));
        if (currentPage === pages) next.disabled = true;
        btns.appendChild(next);

        document.getElementById('pagingWrap').style.display = total <= PAGE_SIZE && pages === 1 ? 'none' : 'flex';
    }

    function makePageBtn(html, fn) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'page-btn'; b.innerHTML = html;
        b.addEventListener('click', fn);
        return b;
    }

    function goPage(p) {
        const filtered = (currentView === 'grid'
            ? [...document.querySelectorAll('#customersGrid .customer-card')]
            : [...document.querySelectorAll('#customersList .customer-list-item')]
        ).filter(c => c.getAttribute('data-show') === '1');
        const pages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        currentPage = Math.max(1, Math.min(pages, p));
        buildPaging();
    }

        function openEditModal(id) {
        fetch(`/Admin/Customer/GetCustomerJson?id=${id}`)
            .then(r => r.json())
            .then(c => {
                document.getElementById('editCustomerId').value = c.customerId;
                document.getElementById('editName').value = c.name || '';
                document.getElementById('editSurname').value = c.surname || '';
                document.getElementById('editEmail').value = c.email || '';
                document.getElementById('editPhone').value = c.phone || '';
                document.getElementById('editIdentityNumber').value = c.identityNumber || '';
                document.getElementById('editDrivingLicenseNumber').value = c.drivingLicenseNumber || '';
                if (c.drivingLicenseDate) {
                    document.getElementById('editDrivingLicenseDate').value = c.drivingLicenseDate.split('T')[0];
                }
                document.getElementById('editModalSubtitle').textContent = `${c.name} ${c.surname} — bilgilerini güncelleyin`;
                new bootstrap.Modal(document.getElementById('editCustomerModal')).show();
            });
    }

    function openDeleteModal(id, name) {
        document.getElementById('deleteCustomerName').textContent = `"${name}"`;
        document.getElementById('deleteCustomerId').value = id;
        document.getElementById('deleteForm').action = `/Admin/Customer/DeleteCustomer/${id}`;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    document.addEventListener('DOMContentLoaded', () => applyFilters());
</script>
