@model List<Rentaly.DTOLayer.CustomerDtos.ResultCustomerDto>
@{
    ViewData["Title"] = "Müşteriler";
    ViewData["ActiveMenu"] = "Customer";
    ViewData["BreadcrumbParent"] = "Operasyon";
    Layout = "_AdminLayout";
}

<style>
    /* ── Mini Stat Cards ── */
    .mini-stat {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: var(--transition);
    }

        .mini-stat:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .mini-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .mini-stat-val {
        font-size: 24px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
    }

    .mini-stat-label {
        font-size: 12.5px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    /* ── Toolbar ── */
    .customer-toolbar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        box-shadow: var(--shadow-sm);
        margin-bottom: 20px;
    }

    .customer-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

        .customer-search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
        }

        .customer-search-wrap input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 12px 9px 36px;
            font-size: 13.5px;
            color: var(--text-primary);
            background: var(--bg);
            outline: none;
            transition: var(--transition);
        }

            .customer-search-wrap input:focus {
                border-color: var(--accent2);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(13,122,69,0.1);
            }

    /* ── Customer Cards Grid ── */
    .customers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 18px;
        margin-bottom: 20px;
    }

    .customer-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .customer-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
            border-color: var(--accent2);
        }

    .customer-card-accent {
        height: 5px;
        background: linear-gradient(90deg, var(--navy) 0%, var(--accent2) 100%);
        flex-shrink: 0;
    }

    .customer-card-header {
        padding: 18px 18px 14px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        border-bottom: 1px solid var(--border);
    }

    .customer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--navy) 0%, var(--accent2) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .customer-card-title-block {
        flex: 1;
        min-width: 0;
    }

    .customer-card-name {
        font-size: 15px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .customer-card-id {
        display: inline-block;
        margin-top: 4px;
        background: var(--bg2);
        border: 1px solid var(--border);
        color: var(--navy);
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 5px;
        letter-spacing: .5px;
    }

    .customer-card-body {
        padding: 16px 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .customer-info-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .customer-info-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
        margin-top: 1px;
    }

        .customer-info-icon.email {
            background: #eff6ff;
            color: #3b82f6;
        }

        .customer-info-icon.phone {
            background: #f0fdf4;
            color: #16a34a;
        }

        .customer-info-icon.license {
            background: var(--bg2);
            color: var(--navy);
        }

        .customer-info-icon.id-num {
            background: #fff7ed;
            color: #ea580c;
        }

    .customer-info-text {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .customer-info-label {
        font-size: 11px;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        line-height: 1;
        margin-bottom: 2px;
    }

    .customer-info-value {
        font-size: 13.5px;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.4;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .customer-card-footer {
        padding: 12px 16px;
        border-top: 1px solid var(--border);
        background: var(--bg2);
        display: flex;
        gap: 8px;
    }

    /* ── List View ── */
    .customers-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
    }

    .customer-list-item {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 18px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .customer-list-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: linear-gradient(180deg, var(--navy) 0%, var(--accent2) 100%);
            border-radius: 4px 0 0 4px;
        }

        .customer-list-item:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
            border-color: var(--accent2);
        }

    .customer-list-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--navy) 0%, var(--accent2) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .customer-list-info {
        flex: 1;
        min-width: 0;
    }

    .customer-list-name {
        font-size: 14.5px;
        font-weight: 800;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .customer-list-id-badge {
        background: var(--bg2);
        border: 1px solid var(--border);
        color: var(--navy);
        font-size: 10.5px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 4px;
        letter-spacing: .5px;
    }

    .customer-list-sub {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 5px;
        flex-wrap: wrap;
    }

    .customer-list-meta {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12.5px;
        color: var(--text-muted);
    }

        .customer-list-meta i {
            font-size: 11px;
            color: var(--accent2);
        }

    .customer-list-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    /* ── Shared btn ── */
    .tbl-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 13px;
        border-radius: var(--radius-sm);
        font-size: 12.5px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        border: none;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

    .tbl-btn-edit {
        background: #fef3c7;
        color: #92400e;
    }

        .tbl-btn-edit:hover {
            background: #f59e0b;
            color: #fff;
        }

    .tbl-btn-delete {
        background: #fee2e2;
        color: var(--danger);
    }

        .tbl-btn-delete:hover {
            background: var(--danger);
            color: #fff;
        }

    /* ── View toggle ── */
    .view-toggle {
        display: flex;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
    }

    .view-btn {
        width: 36px;
        height: 36px;
        border: none;
        background: #fff;
        color: var(--text-muted);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

        .view-btn.active {
            background: var(--navy);
            color: #fff;
        }

        .view-btn:hover:not(.active) {
            background: var(--bg2);
            color: var(--navy);
        }

    /* ── Empty State ── */
    .empty-state {
        padding: 64px 20px;
        text-align: center;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        background: var(--bg2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: var(--navy);
        margin: 0 auto 18px;
    }

    /* ── Pagination ── */
    .paging-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 4px;
        flex-wrap: wrap;
        gap: 8px;
    }

    .paging-info {
        font-size: 13px;
        color: var(--text-muted);
    }

    .paging-btns {
        display: flex;
        gap: 4px;
    }

    .page-btn {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        background: #fff;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        color: var(--text-primary);
    }

        .page-btn:hover {
            background: var(--bg2);
            border-color: var(--accent2);
            color: var(--accent2);
        }

        .page-btn.active {
            background: var(--navy);
            border-color: var(--navy);
            color: #fff;
        }

        .page-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

    .license-date-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
        font-size: 11.5px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 6px;
    }

    @@media (max-width: 575px) {
        .customers-grid {
            grid-template-columns: 1fr;
        }

        .customer-list-meta:not(:first-child) {
            display: none;
        }
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Müşteri Listesi</h1>
        <p class="page-subtitle">Tüm müşterileri görüntüleyin ve yönetin.</p>
    </div>
    <a asp-area="Admin" asp-controller="Customer" asp-action="CreateCustomer" class="btn-add">
        <i class="ti ti-plus"></i> Yeni Müşteri
    </a>
</div>

<!-- Mini İstatistikler -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:var(--bg2);color:var(--navy);">
                <i class="ti ti-users"></i>
            </div>
            <div>
                <div class="mini-stat-val">@Model.Count()</div>
                <div class="mini-stat-label">Toplam Müşteri</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#d1fae5;color:#059669;">
                <i class="ti ti-id-badge"></i>
            </div>
            <div>
                <div class="mini-stat-val" style="color:#059669;">
                    @Model.Count(c => !string.IsNullOrEmpty(c.DrivingLicenseNumber))
                </div>
                <div class="mini-stat-label">Ehliyeti Olan</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#fff7ed;color:#ea580c;">
                <i class="ti ti-mail"></i>
            </div>
            <div>
                <div class="mini-stat-val" style="color:#ea580c;">
                    @Model.Count(c => !string.IsNullOrEmpty(c.Email))
                </div>
                <div class="mini-stat-label">E-postası Kayıtlı</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#eff6ff;color:#3b82f6;">
                <i class="ti ti-phone"></i>
            </div>
            <div>
                <div class="mini-stat-val" style="color:#3b82f6;">
                    @Model.Count(c => !string.IsNullOrEmpty(c.Phone))
                </div>
                <div class="mini-stat-label">Telefonu Kayıtlı</div>
            </div>
        </div>
    </div>
</div>

<!-- Toolbar -->
<div class="customer-toolbar">
    <div class="customer-search-wrap">
        <i class="ti ti-search"></i>
        <input type="text" id="customerSearch" placeholder="Ad, soyad, e-posta, telefon ara…" oninput="filterCustomers()" />
    </div>
    <select class="form-select" id="sortSelect" onchange="filterCustomers()" style="min-width:200px;font-size:13px;">
        <option value="id-asc">ID — Artan</option>
        <option value="id-desc">ID — Azalan</option>
        <option value="name-asc">Ad — A'dan Z'ye</option>
        <option value="name-desc">Ad — Z'den A'ya</option>
        <option value="surname-asc">Soyad — A'dan Z'ye</option>
        <option value="surname-desc">Soyad — Z'den A'ya</option>
        <option value="license-asc">Ehliyet Tarihi — Eski→Yeni</option>
        <option value="license-desc">Ehliyet Tarihi — Yeni→Eski</option>
    </select>
    <div class="view-toggle">
        <button class="view-btn active" id="btnGridView" onclick="setView('grid')" title="Kart Görünümü">
            <i class="ti ti-layout-grid"></i>
        </button>
        <button class="view-btn" id="btnListView" onclick="setView('list')" title="Liste Görünümü">
            <i class="ti ti-list"></i>
        </button>
    </div>
    <button onclick="resetCustomerFilters()" class="btn-edit" style="white-space:nowrap;">
        <i class="ti ti-rotate-left"></i> Sıfırla
    </button>
</div>

<!-- Kart Grid Görünümü -->
<div class="customers-grid" id="customersGrid">
    @foreach (var customer in Model)
    {
        var initials = $"{(string.IsNullOrEmpty(customer.Name) ? "?" : customer.Name[0].ToString())}{(string.IsNullOrEmpty(customer.Surname) ? "" : customer.Surname[0].ToString())}".ToUpper();
        var fullName = $"{customer.Name} {customer.Surname}".Trim();

        <div class="customer-card"
             data-id="@customer.CustomerId"
             data-name="@customer.Name?.ToLower()"
             data-surname="@customer.Surname?.ToLower()"
             data-email="@customer.Email?.ToLower()"
             data-phone="@customer.Phone?.ToLower()"
             data-license-date="@customer.DrivingLicenseDate.Ticks">

            <div class="customer-card-accent"></div>

            <div class="customer-card-header">
                <div class="customer-avatar">@initials</div>
                <div class="customer-card-title-block">
                    <div class="customer-card-name">@fullName</div>
                    <span class="customer-card-id"># @customer.CustomerId</span>
                </div>
            </div>

            <div class="customer-card-body">
                <div class="customer-info-row">
                    <div class="customer-info-icon email"><i class="ti ti-mail"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">E-posta</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.Email) ? "—" : customer.Email)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon phone"><i class="ti ti-phone"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">Telefon</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.Phone) ? "—" : customer.Phone)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon id-num"><i class="ti ti-fingerprint"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">TC Kimlik No</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.IdentityNumber) ? "—" : customer.IdentityNumber)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon license"><i class="ti ti-id-badge"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">Ehliyet No / Tarih</span>
                        <span class="customer-info-value">
                            @(string.IsNullOrEmpty(customer.DrivingLicenseNumber) ? "—" : customer.DrivingLicenseNumber)
                            @if (customer.DrivingLicenseDate != default)
                            {
                                <span class="license-date-badge" style="margin-left:4px;">
                                    <i class="ti ti-calendar-check" style="font-size:10px;"></i>
                                    @customer.DrivingLicenseDate.ToString("dd.MM.yyyy")
                                </span>
                            }
                        </span>
                    </div>
                </div>
            </div>

            <div class="customer-card-footer">
                <button class="tbl-btn tbl-btn-edit"
                        onclick="openEditModal(@customer.CustomerId)">
                    <i class="ti ti-pencil"></i> Düzenle
                </button>
                <button class="tbl-btn tbl-btn-delete"
                        onclick="openDeleteModal(@customer.CustomerId, '@fullName')">
                    <i class="ti ti-trash"></i> Sil
                </button>
            </div>
        </div>
    }
</div>

<!-- Liste Görünümü -->
<div class="customers-list" id="customersList" style="display:none;">
    @foreach (var customer in Model)
    {
        var initials = $"{(string.IsNullOrEmpty(customer.Name) ? "?" : customer.Name[0].ToString())}{(string.IsNullOrEmpty(customer.Surname) ? "" : customer.Surname[0].ToString())}".ToUpper();
        var fullName = $"{customer.Name} {customer.Surname}".Trim();

        <div class="customer-list-item"
             data-id="@customer.CustomerId"
             data-name="@customer.Name?.ToLower()"
             data-surname="@customer.Surname?.ToLower()"
             data-email="@customer.Email?.ToLower()"
             data-phone="@customer.Phone?.ToLower()"
             data-license-date="@customer.DrivingLicenseDate.Ticks">

            <div class="customer-list-avatar">@initials</div>
            <div class="customer-list-info">
                <div class="customer-list-name">
                    @fullName
                    <span class="customer-list-id-badge">#@customer.CustomerId</span>
                </div>
                <div class="customer-list-sub">
                    <span class="customer-list-meta">
                        <i class="ti ti-mail"></i>
                        @(string.IsNullOrEmpty(customer.Email) ? "E-posta yok" : customer.Email)
                    </span>
                    <span style="color:var(--border);">·</span>
                    <span class="customer-list-meta">
                        <i class="ti ti-phone"></i>
                        @(string.IsNullOrEmpty(customer.Phone) ? "Telefon yok" : customer.Phone)
                    </span>
                    <span style="color:var(--border);">·</span>
                    <span class="customer-list-meta">
                        <i class="ti ti-id-badge"></i>
                        @(string.IsNullOrEmpty(customer.DrivingLicenseNumber) ? "Ehliyet yok" : customer.DrivingLicenseNumber)
                        @if (customer.DrivingLicenseDate != default)
                        {
                            <span style="margin-left:4px;color:#16a34a;">(@customer.DrivingLicenseDate.ToString("dd.MM.yyyy"))</span>
                        }
                    </span>
                </div>
            </div>
            <div class="customer-list-actions">
                <button class="tbl-btn tbl-btn-edit" style="flex:none;padding:7px 10px;"
                        onclick="openEditModal(@customer.CustomerId)">
                    <i class="ti ti-pencil"></i>
                </button>
                <button class="tbl-btn tbl-btn-delete" style="flex:none;padding:7px 10px;"
                        onclick="openDeleteModal(@customer.CustomerId, '@fullName')">
                    <i class="ti ti-trash"></i>
                </button>
            </div>
        </div>
    }
</div>

<!-- Boş Durum -->
<div class="empty-state" id="emptyState" style="display:none;">
    <div class="empty-icon"><i class="ti ti-users-off"></i></div>
    <h6 style="font-weight:700;margin-bottom:6px;color:var(--text-primary);">Müşteri Bulunamadı</h6>
    <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:14px;">Arama veya filtre kriterinizle eşleşen müşteri yok.</p>
    <button onclick="resetCustomerFilters()" class="btn-add">
        <i class="ti ti-rotate-left"></i> Filtreyi Temizle
    </button>
</div>

<!-- Pagination -->
<div class="paging-wrap" id="pagingWrap" style="display:none;">
    <div class="paging-info" id="pagingInfo">—</div>
    <div class="paging-btns" id="pagingBtns"></div>
</div>

<!-- Sil Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border:none;border-radius:14px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border);padding:18px 22px;background:var(--bg2);border-radius:14px 14px 0 0;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:#fee2e2;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--danger);">
