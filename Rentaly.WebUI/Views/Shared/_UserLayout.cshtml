@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">

<head>
    <title>@(ViewData["Title"] ?? "RentCar - Araç Kiralama")</title>
    <link rel="icon" href="~/images/icon.png" type="image/gif" sizes="16x16">
    <meta content="text/html;charset=utf-8" http-equiv="Content-Type">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="RentCar - Araç Kiralama Hizmetleri" name="description">
    <!-- CSS Files
    ================================================== -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet" type="text/css" id="bootstrap">
    <link href="~/css/mdb.min.css" rel="stylesheet" type="text/css" id="mdb">
    <link href="~/css/plugins.css" rel="stylesheet" type="text/css">
    <link href="~/css/style.css" rel="stylesheet" type="text/css">
    <link href="~/css/coloring.css" rel="stylesheet" type="text/css">
    <!-- color scheme -->
    <link id="colors" href="~/css/colors/scheme-01.css" rel="stylesheet" type="text/css">
    @await RenderSectionAsync("Styles", required: false)
</head>

<body onload="initialize()">
    <div id="wrapper">

        <!-- page preloader begin -->
        <div id="de-preloader"></div>
        <!-- page preloader close -->
        <!-- header begin -->
        <header class="transparent scroll-light has-topbar">
            <div id="topbar" class="topbar-dark text-light">
                <div class="container">
                    <div class="topbar-left xs-hide">
                        <div class="topbar-widget">
                            <div class="topbar-widget"><a href="tel:+908501234567"><i class="fa fa-phone"></i>0850 123 45 67</a></div>
                            <div class="topbar-widget"><a href="mailto:destek@rentcar.com"><i class="fa fa-envelope"></i>destek@rentcar.com</a></div>
                            <div class="topbar-widget"><a href="#"><i class="fa fa-clock-o"></i>Pzt - Cuma 08:00 - 18:00</a></div>
                        </div>
                    </div>

                    <div class="topbar-right">
                        <div class="social-icons">
                            <a href="#"><i class="fa fa-facebook fa-lg"></i></a>
                            <a href="#"><i class="fa fa-twitter fa-lg"></i></a>
                            <a href="#"><i class="fa fa-instagram fa-lg"></i></a>
                        </div>
                    </div>
                    <div class="clearfix"></div>
                </div>
            </div>
            <div class="container">
                <div class="row">
                    <div class="col-md-12">
                        <div class="de-flex sm-pt10">
                            <div class="de-flex-col">
                                <div class="de-flex-col">
                                    <!-- logo begin -->
                                    <div id="logo">
                                        <a asp-controller="Home" asp-action="Index">
                                            <img class="logo-1" src="~/images/logo-light.png" alt="RentCar">
                                            <img class="logo-2" src="~/images/logo.png" alt="RentCar">
                                        </a>
                                    </div>
                                    <!-- logo close -->
                                </div>
                            </div>
                            <div class="de-flex-col header-col-mid">
                                <ul id="mainmenu">
                                    <li><a class="menu-item" asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                                    <li><a class="menu-item" asp-controller="Car" asp-action="CarList">Araçlar</a></li>
                                    <li><a class="menu-item" asp-controller="Home" asp-action="About">Hakkımızda</a></li>
                                    <li><a class="menu-item" asp-controller="Booking" asp-action="QuickBooking">Rezervasyon</a></li>      
                                </ul>
                            </div>
                            <div class="de-flex-col">
                                <div class="menu_side_area">
                                    <a asp-controller="Car" asp-action="CarList" class="btn-main">Araç Kirala</a>
                                    <span id="menu-btn"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        <!-- header close -->
        <!-- content begin -->
        <div class="no-bottom no-top" id="content">
            <div id="top"></div>

            @RenderBody()

        </div>
        <!-- content close -->

        <a href="#" id="back-to-top"></a>

        <!-- footer begin -->
        <footer class="text-light">
            <div class="container">
                <div class="row g-custom-x">
                    <div class="col-lg-3">
                        <div class="widget">
                            <h5>RentCar Hakkında</h5>
                            <p>Kalite ve uygun fiyatın buluştuğu nokta. Bütçenizi zorlamadan keyifli ve sorunsuz bir yolculuk deneyimi sunmak için araç filomuzu özenle hazırladık.</p>
                        </div>
                    </div>

                    <div class="col-lg-3">
                        <div class="widget">
                            <h5>İletişim Bilgileri</h5>
                            <address class="s1">
                                <span><i class="id-color fa fa-map-marker fa-lg"></i>İstanbul, Türkiye</span>
                                <span><i class="id-color fa fa-phone fa-lg"></i>0850 123 45 67</span>
                                <span><i class="id-color fa fa-envelope-o fa-lg"></i><a href="mailto:destek@rentcar.com">destek@rentcar.com</a></span>
                            </address>
                        </div>
                    </div>

                    <div class="col-lg-3">
                        <h5>Hızlı Linkler</h5>
                        <div class="row">
                            <div class="col-lg-6">
                                <div class="widget">
                                    <ul>
                                        <li><a asp-controller="Home" asp-action="About">Hakkımızda</a></li>
                                        <li><a asp-controller="Car" asp-action="CarList">Araçlar</a></li>
                                        <li><a asp-controller="Booking" asp-action="Index">Rezervasyon</a></li>
                                        <li><a asp-controller="Home" asp-action="Contact">İletişim</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3">
                        <div class="widget">
                            <h5>Sosyal Medya</h5>
                            <div class="social-icons">
                                <a href="#"><i class="fa fa-facebook fa-lg"></i></a>
                                <a href="#"><i class="fa fa-twitter fa-lg"></i></a>
                                <a href="#"><i class="fa fa-instagram fa-lg"></i></a>
                                <a href="#"><i class="fa fa-linkedin fa-lg"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="subfooter">
                <div class="container">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="de-flex">
                                <div class="de-flex-col">
                                    <a asp-controller="Home" asp-action="Index">
                                        © 2026 RentCar — Tüm Hakları Saklıdır
                                    </a>
                                </div>
                                <ul class="menu-simple">
                                    <li><a href="#">Kullanım Koşulları</a></li>
                                    <li><a href="#">Gizlilik Politikası</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
        <!-- footer close -->
    </div>

    <!-- Javascript Files
    ================================================== -->
    <script src="~/js/plugins.js"></script>
    <script src="~/js/designesia.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
